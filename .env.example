# Copy to `.env` and fill in secrets. Django loads `.env` from the project root.

# --- Django ---
DJANGO_SECRET_KEY=your_secret_key_here
DEBUG=True
ALLOWED_HOSTS=localhost 127.0.0.1

# --- Database ---
# Recommended for this app: PostgreSQL (models use PostgreSQL-specific fields).
# Start local Postgres: `docker compose up -d` (listens on host port 5433).
DATABASE_URL=postgresql://promptcraft:promptcraft@127.0.0.1:5433/promptcraft
#
# Optional: omit DATABASE_URL to use SQLite at `db.sqlite3` (may not match
# production; prefer Postgres for local dev).

# --- OpenAI ---
OPENAI_API_KEY=your_openai_api_key_here
GENERATE_MODEL=gpt-4o
EVAL_MODEL=gpt-4o
# Optional: max completion tokens for /api/generate (default 16384)
# GENERATE_MAX_TOKENS=16384

# --- Production examples (uncomment and adjust) ---
# DEBUG=False
# ALLOWED_HOSTS=your-app.onrender.com
# DATABASE_URL=postgresql://<user>:<password>@<host>:5432/promptcraft
