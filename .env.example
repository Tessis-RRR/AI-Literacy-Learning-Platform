DJANGO_SECRET_KEY=your_secret_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Local dev (Docker on port 5433)
DATABASE_URL=postgresql://promptcraft:promptcraft@127.0.0.1:5433/promptcraft

# Production (Render PostgreSQL)
# DATABASE_URL=postgresql://<user>:<password>@<host>:5432/promptcraft

GENERATE_MODEL=gpt-4o
EVAL_MODEL=gpt-4o
# Optional: cap lesson generation length (default 16384). Lower only if you need shorter outputs or lower cost.
# GENERATE_MAX_TOKENS=16384

# Local dev
DEBUG=True
ALLOWED_HOSTS=localhost 127.0.0.1

# Production
# DEBUG=False
# ALLOWED_HOSTS=your-app.onrender.com
